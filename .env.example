# ERPilot AI - ornek ortam degiskenleri
# Bu dosyayi .env olarak kopyalayip degerleri doldurun.

# Gemini API anahtari (zorunlu degil; bos birakilirsa lokal fallback motoru calisir)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Veri kaynagi: csv | sap
DATA_SOURCE=csv

# CSV veri klasoru (backend/ klasorune gore)
DATA_DIR=data

# Sunucu
HOST=127.0.0.1
PORT=8000

# CORS - izin verilen origin'ler (virgulle ayrilir)
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Gemini rate limiting
CHAT_RATE_LIMIT=10/minute
GEMINI_MAX_CONCURRENCY=3
GEMINI_TIMEOUT_SECONDS=20
CACHE_TTL_SECONDS=120

# SAP entegrasyonu (future work - su an kullanilmiyor)
SAP_ODATA_BASE_URL=
SAP_ODATA_USER=
SAP_ODATA_PASSWORD=
